# Google Apps Script endpoint used by existing flow
GOOGLE_SHEETS_ENDPOINT=

# Optional auth/session inputs (service will prompt if missing)
X_USERNAME=
X_PASSWORD=
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
FACEBOOK_USERNAME=
FACEBOOK_PASSWORD=
GOOGLE_USERNAME=
GOOGLE_PASSWORD=

# Optional runtime options
HEADLESS_BROWSER=true
MAX_RETRIES=3
BACKOFF_BASE_SECONDS=2
