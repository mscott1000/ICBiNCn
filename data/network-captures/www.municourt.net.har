            "text": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <meta charset=\"utf-8\" />\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=Edge\">\r\n    <title>Full Case View - MuniCourtNet</title>\r\n\r\n    <link href=\"/Content/css?v=gxAbbQth6BYWLtNkeixpDWDnnnotwRv-_XuiWj82ev01\" rel=\"stylesheet\"/>\r\n\r\n    <script src=\"/bundles/modernizr?v=wBEWDufH_8Md-Pbioxomt90vm6tJN2Pyy9u9zHtWsPo1\"></script>\r\n\r\n    <script id=\"recaptcha\" async defer></script>\r\n    <script>\r\n        sessionStorage.recaptchaSiteKey = \"6LdjA74ZAAAAAB1Q9N0cHDrRk8XyW7vWAy3W2Bhy\";\r\n        document.getElementById('recaptcha').src = \"https://www.google.com/recaptcha/api.js?render=\" + sessionStorage.recaptchaSiteKey;\r\n    </script>\r\n\r\n    \r\n    <script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-135313992-1\"></script>\r\n    <script>\r\n        window.dataLayer = window.dataLayer || [];\r\n        function gtag() { dataLayer.push(arguments); }\r\n        gtag('js', new Date());\r\n        gtag('config', 'UA-135313992-1');\r\n    </script>\r\n\r\n</head>\r\n<body>\r\n\r\n\t<div class=\"navbar navbar-static-top mcn-navbar\">\r\n\t\t<div class=\"container\">\r\n\t\t\t<div class=\"navbar-header\">\r\n\t\t\t\t<div>\r\n\t\t\t\t\t<a id=\"lnkHome\" name=\"lnkHome\" href=\"/\">\r\n\t\t\t\t\t\t<img id=\"imgLogo\" name=\"imgLogo\" src=\"/Content/images/MunicourtNet_logo-b.png\" />\r\n\t\t\t\t\t</a>\r\n\t\t\t\t\t<span id=\"versiondisplay\"></span>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</div>\r\n\r\n\t<div id=\"mcn-centercontent\">\r\n\r\n\t\t<div class=\"container body-content\">\r\n\t\t\t\r\n\r\n\r\n<div>\r\n    <br />\r\n    <div class=\"divrow\">\r\n        <span>Status:</span>\r\n        <span>Warrant</span>\r\n    </div>\r\n\r\n    <div class=\"divrow\">\r\n        <span>Case #:</span>&nbsp;\r\n        <span>180290258-8</span>&nbsp;&nbsp;&nbsp;\r\n        <span>Ticket #:</span>&nbsp;\r\n        <span>180290258</span>&nbsp;&nbsp;&nbsp;\r\n        <span>OCN:</span>&nbsp;\r\n        <span></span>\r\n    </div>\r\n    <div class=\"divrow\">\r\n        <span>Court Name:</span>&nbsp;\r\n        <span>Florissant Municipal Court</span>\r\n\r\n            <span>Bond Set Amount:</span>&nbsp;\r\n            <span>&#36;100.00</span>\r\n    </div>\r\n    <div class=\"divrow\">\r\n        <span>Website:</span>&nbsp;\r\n        \r\n        <span><a href=\"https://www.florissantmo.com\" target=\"_blank\">www.florissantmo.com</a></span>\r\n    </div>\r\n\r\n\r\n    <div class=\"divline\"></div>\r\n    <div class=\"divrow\">\r\n        <span>Defendant:</span>&nbsp;\r\n        <span>Jasmine L Williams </span>\r\n    </div>\r\n    <div class=\"divrow\">\r\n        <span>Birth Year:</span>&nbsp;\r\n        <span>\r\n1994        </span>\r\n    </div>\r\n    <div class=\"divrow\">\r\n        <span>Address:</span>&nbsp;\r\n        <span>453 Plaza Ave  St Louis, MO  63135</span>\r\n    </div>\r\n    <div class=\"divline\"></div>\r\n    <div class=\"divrow\">\r\n        <span>Violation Information</span>\r\n    </div>\r\n    <div class=\"divgroup1\">\r\n        <div class=\"divrow\">\r\n            <span>Date/Time:</span>&nbsp;\r\n            <span>06/19/2018 10:18 AM</span>&nbsp;&nbsp;&nbsp;\r\n        </div>\r\n        <div class=\"divrow\">\r\n            <span>Location:</span>&nbsp;\r\n            <span>1 Flower Valley Ent (S</span>&nbsp;&nbsp;&nbsp;\r\n        </div>\r\n        <div class=\"divrow\">\r\n            <span>Issuing Agency:</span>&nbsp;\r\n            <span>Florissant Police Department</span>&nbsp;&nbsp;&nbsp;\r\n        </div>\r\n    </div>\r\n    <div class=\"divline\"></div>\r\n    <div class=\"divrow\">\r\n        <span>Charge Information</span>\r\n    </div>\r\n    <div class=\"divDisposition\">\r\n        <div class=\"divrow\">\r\n            <span>Charge:</span>&nbsp;&nbsp;\r\n            <span>95101990</span>&nbsp;&nb