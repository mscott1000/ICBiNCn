                                          block('<<<<<<<<<<<<<<<<<<<<<< ELIGIBLE >>>>>>>>>>>>>>>>>>>>>>',urgent),
                                          block('<<<<<<<<<<<<<<<<<<<< REFER TO CITY >>>>>>>>>>>>>>>>>>>',refer),
                                          block('<<<<<<<<<<<<<<<<<<<<< INELIGIBLE >>>>>>>>>>>>>>>>>>>>>',less),].join('\n');}


